#!/usr/bin/env bash

set -euo pipefail

TASK=${1:-}
if [ -z "$TASK" ]; then
  echo "Usage: ai-plan <task-name>"
  exit 1
fi

TASK_FILE=".ai/tasks/$TASK.md"
if [ ! -f "$TASK_FILE" ]; then
  echo "Task not found: $TASK_FILE"
  exit 1
fi

if [ ! -f .ai/config.yaml ]; then
  echo "Missing .ai/config.yaml"
  exit 1
fi

CONTEXT_FILES=$(awk '
  /^context:/ { in_context=1; next }
  in_context && /^  - / {
    sub(/^  - /, "", $0)
    print
    next
  }
  in_context && $0 !~ /^  - / { in_context=0 }
' .ai/config.yaml)

codex "$(
  echo "TASK CONTEXT"
  echo "------------------------------------"
  cat "$TASK_FILE"

  echo
  echo "CANONICAL CONTEXT"
  echo "------------------------------------"
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    [ -f "$f" ] || continue
    echo
    echo "## FILE: $f"
    cat "$f"
  done <<< "$CONTEXT_FILES"

  echo
  echo "PROMPT"
  echo "------------------------------------"
  cat .ai/prompts/breakdown.md
)"
