#!/usr/bin/env bash

TASK=$1

if [ -z "$TASK" ]; then
  echo "Usage: ai-run <task-name>"
  exit 1
fi

TASK_FILE=".ai/tasks/$TASK.md"

if [ ! -f "$TASK_FILE" ]; then
  echo "Task not found: $TASK_FILE"
  exit 1
fi

TYPE=$(echo "$TASK" | cut -d'_' -f1)

PROMPT=""

case "$TYPE" in
  feature)
    PROMPT=".ai/prompts/execute.md"
    ;;
  refactor)
    PROMPT=".ai/prompts/execute.md"
    ;;
  fix)
    PROMPT=".ai/prompts/fix.md"
    ;;
  test)
    PROMPT=".ai/prompts/test.md"
    ;;
  *)
    echo "Unknown task type: $TYPE"
    exit 1
    ;;
esac

echo
echo "===================================="
echo "Running AI task: $TASK"
echo "Task type: $TYPE"
echo "===================================="
echo

codex "$(
echo "TASK CONTEXT"
echo "------------------------------------"
cat "$TASK_FILE"

echo
echo "FEATURE MAP"
echo "------------------------------------"
cat .ai/context/feature-map.md

echo
echo "SYMBOL MAP"
echo "------------------------------------"
cat .ai/context/symbol-map.md

echo
echo "REPOSITORY MAP"
echo "------------------------------------"
cat .ai/context/repomap.md

echo
echo "FILE INDEX"
echo "------------------------------------"
cat .ai/context/file-index.md

echo
echo "ARCHITECTURE CONTEXT"
echo "------------------------------------"
cat .ai/context/architecture.md

echo
echo "FRAMEWORK CONTEXT"
echo "------------------------------------"
cat .ai/context/framework-go-core.md

echo
echo "ENGINEERING RULES"
echo "------------------------------------"
cat .ai/context/engineering-rules.md

echo
echo "OWNERSHIP MAP"
echo "------------------------------------"
cat .ai/context/ownership.md

echo
echo "CHANGE SCOPE GUARD"
echo "------------------------------------"
echo "Only modify files inside the Allowed Paths defined in the task context."
echo "Never modify files outside the defined task scope."

echo
echo "PROMPT"
echo "------------------------------------"
cat "$PROMPT"
)"