#!/usr/bin/env bash

set -euo pipefail

TASK=${1:-}
if [ -z "$TASK" ]; then
  echo "Usage: ai-run <task-name>"
  exit 1
fi

TASK_FILE=".ai/tasks/$TASK.md"
if [ ! -f "$TASK_FILE" ]; then
  echo "Task not found: $TASK_FILE"
  exit 1
fi

TYPE=$(echo "$TASK" | cut -d'_' -f1)
case "$TYPE" in
  feature|refactor) PROMPT=".ai/prompts/execute.md" ;;
  fix) PROMPT=".ai/prompts/fix.md" ;;
  test) PROMPT=".ai/prompts/test.md" ;;
  *)
    echo "Unknown task type: $TYPE"
    exit 1
    ;;
esac

if [ ! -f .ai/config.yaml ]; then
  echo "Missing .ai/config.yaml"
  exit 1
fi

CONTEXT_FILES=$(awk '
  /^context:/ { in_context=1; next }
  in_context && /^  - / {
    sub(/^  - /, "", $0)
    print
    next
  }
  in_context && $0 !~ /^  - / { in_context=0 }
' .ai/config.yaml)

echo
echo "===================================="
echo "Running AI task: $TASK"
echo "Task type: $TYPE"
echo "===================================="
echo

codex "$(
  echo "TASK CONTEXT"
  echo "------------------------------------"
  cat "$TASK_FILE"

  echo
  echo "CANONICAL CONTEXT"
  echo "------------------------------------"
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    if [ -f "$f" ]; then
      echo
      echo "## FILE: $f"
      cat "$f"
    fi
  done <<< "$CONTEXT_FILES"

  echo
  echo "PROMPT"
  echo "------------------------------------"
  cat "$PROMPT"
)"
