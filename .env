# ==============================
# APPLICATION
# ==============================

SERVICE_NAME=transaction-history-service
APP_ENV=local
LOG_LEVEL=debug
SHUTDOWN_TIMEOUT=10s
MIGRATION_AUTO_RUN=false
MIGRATION_DB=transaction
MIGRATION_DIR=migrations/transaction

# ==============================
# DATABASE
# ==============================

DB_LIST=transaction,history

DB_TRANSACTION_DRIVER=sqlserver
DB_TRANSACTION_HOST=localhost
DB_TRANSACTION_PORT=1433
DB_TRANSACTION_NAME=master
DB_TRANSACTION_USER=sa
DB_TRANSACTION_PASSWORD=YourStrong!Passw0rd
DB_TRANSACTION_PARAMS=

DB_HISTORY_DRIVER=mysql
DB_HISTORY_HOST=localhost
DB_HISTORY_PORT=3306
DB_HISTORY_NAME=app_db
DB_HISTORY_USER=app_user
DB_HISTORY_PASSWORD=app_pass
DB_HISTORY_PARAMS=parseTime=true&loc=Local
# Optional (defaults if omitted)
# DB_TRANSACTION_MAX_OPEN_CONNS=20
# DB_TRANSACTION_MAX_IDLE_CONNS=10
# DB_TRANSACTION_CONN_MAX_LIFETIME=5m
# DB_HISTORY_MAX_OPEN_CONNS=20
# DB_HISTORY_MAX_IDLE_CONNS=10
# DB_HISTORY_CONN_MAX_LIFETIME=5m

# ==============================
# TRANSPORT
# ==============================

GRPC_PORT=9090
HTTP_PORT=8080

# ==============================
# OBSERVABILITY
# ==============================

OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_SAMPLING_RATIO=0

# ==============================
# INTERNAL JWT
# ==============================

INTERNAL_JWT_ENABLED=false
INTERNAL_JWT_PUBLIC_KEY=
INTERNAL_JWT_ISSUER=
INTERNAL_JWT_AUDIENCE=
