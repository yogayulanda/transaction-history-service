# ==============================
# APPLICATION
# ==============================

SERVICE_NAME=transaction-history-service
APP_ENV=local
LOG_LEVEL=debug
SHUTDOWN_TIMEOUT=10s
MIGRATION_AUTO_RUN=true
MIGRATION_DB=transaction_history
MIGRATION_DIR=migrations/transaction

# ==============================
# DATABASE
# ==============================

DB_LIST=transaction_history

DB_TRANSACTION_HISTORY_DRIVER=sqlserver
DB_TRANSACTION_HISTORY_HOST=localhost
DB_TRANSACTION_HISTORY_PORT=1433
DB_TRANSACTION_HISTORY_NAME=transaction_history
DB_TRANSACTION_HISTORY_USER=sa
DB_TRANSACTION_HISTORY_PASSWORD=YourStrong!Passw0rd
DB_TRANSACTION_HISTORY_PARAMS=

# Optional (defaults if omitted)
# DB_TRANSACTION_HISTORY_MAX_OPEN_CONNS=20
# DB_TRANSACTION_HISTORY_MAX_IDLE_CONNS=10
# DB_TRANSACTION_HISTORY_CONN_MAX_IDLE_TIME=2m
# DB_TRANSACTION_HISTORY_CONN_MAX_LIFETIME=5m

# ==============================
# TRANSPORT
# ==============================

GRPC_PORT=9090
HTTP_PORT=8080

# ==============================
# OBSERVABILITY
# ==============================

OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_SAMPLING_RATIO=0

# ==============================
# INTERNAL JWT
# ==============================

INTERNAL_JWT_ENABLED=false
INTERNAL_JWT_PUBLIC_KEY=
INTERNAL_JWT_ISSUER=
INTERNAL_JWT_AUDIENCE=
